[gd_scene load_steps=2 format=3 uid="uid://bu8hq3vdi4fhp"]

[sub_resource type="GDScript" id="GDScript_km2j7"]
script/source = "## BattleScene - 对战场景核心控制器
##
## 职责：
## - 管理玩家和敌方的手牌显示
## - 处理卡牌悬停、选中动画
## - 管理对战流程状态
## - 与BattleUI.gd系统通信
class_name BattleScene
extends Control

# ========== 信号定义 ==========
signal card_selected(card_index: int, card_id: String)
signal card_deselected(card_index: int, card_id: String)
signal selection_confirmed(selected_indices: Array[int])
signal selection_cancelled()
signal battle_started()
signal round_started(round_number: int)
signal round_ended(result: BattleEnums.ERoundResult)

# ========== 常量定义 ==========
const MAX_CARDS_IN_HAND := 6
const MAX_SELECTIONS := 3
const CARD_SCALE_NORMAL := 1.0
const CARD_SCALE_HOVER := 1.15
const CARD_SCALE_SELECTED := 1.2
const CARD_MOVE_DURATION := 0.3
const REVEAL_DURATION := 0.5

# ========== 状态枚举 ==========
enum BattleState {
	IDLE,           # 空闲状态
	PLAYER_SELECT,  # 玩家选择卡牌
	PLAYER_CONFIRM, # 玩家确认选择
	BATTLE_COMPARE, # 对战比较
	ROUND_RESULT,   # 回合结果展示
	BATTLE_END      # 对战结束
}

# ========== 场景节点引用 ==========
@onready var _player_card_container: HBoxContainer = $PlayerHandArea/PlayerCardContainer
@onready var _enemy_card_container: HBoxContainer = $EnemyHandArea/EnemyCardContainer
@onready var _play_button: Button = $ActionButtons/PlayButton
@onready var _cancel_button: Button = $ActionButtons/CancelButton
@onready var _player_selected_container: HBoxContainer = $BattleArea/BattleAreaContainer/BattleContent/PlayerBattleZone/PlayerSelectedCards
@onready var _enemy_selected_container: HBoxContainer = $BattleArea/BattleAreaContainer/BattleContent/EnemyBattleZone/EnemySelectedCards
@onready var _player_total_label: Label = $BattleArea/BattleAreaContainer/BattleContent/PlayerBattleZone/PlayerTotalValue
@onready var _enemy_total_label: Label = $BattleArea/BattleAreaContainer/BattleContent/EnemyBattleZone/EnemyTotalValue
@onready var _battle_result_label: Label = $BattleArea/BattleAreaContainer/BattleContent/VSDivider/BattleResult
@onready var _status_label: Label = $TopInfoPanel/TopInfoContainer/BattleInfo/StatusLabel
@onready var _round_label: Label = $TopInfoPanel/TopInfoContainer/BattleInfo/RoundLabel
@onready var _dialog_text: RichTextLabel = $DialogArea/DialogContainer/DialogText
@onready var _player_score_label: Label = $TopInfoPanel/TopInfoContainer/PlayerInfo/PlayerScore
@onready var _enemy_score_label: Label = $TopInfoPanel/TopInfoContainer/EnemyInfo/EnemyScore
@onready var _enemy_name_label: Label = $TopInfoPanel/TopInfoContainer/EnemyInfo/EnemyName
@onready var _player_name_label: Label = $TopInfoPanel/TopInfoContainer/PlayerInfo/PlayerName
@onready var _animation_player: AnimationPlayer = $AnimationPlayer

# ========== 游戏数据 ==========
var _current_state: BattleState = BattleState.IDLE
var _player_cards: Array[CardInstance] = []
var _enemy_cards: Array[CardInstance] = []
var _selected_indices: Array[int] = []
var _player_score: int = 0
var _enemy_score: int = 0
var _current_round: int = 0
var _target_wins: int = 3
var _current_enemy: EnemyData = null

# ========== 卡牌UI节点 ==========
var _player_card_nodes: Array[CardUI] = []
var _enemy_card_nodes: Array[CardUI] = []
var _card_manager: Node = null
var _data_manager: Node = null
var _event_bus: Node = null

# ========== 对话消息队列 ==========
var _dialog_queue: Array[String] = []
var _dialog_timer: Timer = null

# ========== 动画队列 ==========
var _animation_queue: Array = []

# ========== 生命周期 ==========
func _ready() -> void:
	_initialize_nodes()
	_connect_signals()
	_subscribe_to_events()
	_setup_button_styles()
	_add_dialog(\"对战场景已就绪...\")

func _initialize_nodes() -> void:
	# 尝试获取管理器节点
	if has_node(\"/root/CardMgr\"):
		_card_manager = get_node(\"/root/CardMgr\")
	if has_node(\"/root/DataManager\"):
		_data_manager = get_node(\"/root/DataManager\")
	if has_node(\"/root/EventBus\"):
		_event_bus = get_node(\"/root/EventBus\")

func _connect_signals() -> void:
	_play_button.pressed.connect(_on_play_button_pressed)
	_cancel_button.pressed.connect(_on_cancel_button_pressed)

	# 设置对话框定时器
	_dialog_timer = Timer.new()
	_dialog_timer.one_shot = true
	_dialog_timer.timeout.connect(_on_dialog_timer_timeout)
	add_child(_dialog_timer)

func _subscribe_to_events() -> void:
	if _event_bus:
		_event_bus.subscribe(\"Flow_BattleStart\", _on_flow_battle_start)
		_event_bus.subscribe(\"Flow_PlayerSelecting\", _on_flow_player_selecting)
		_event_bus.subscribe(\"Flow_PlayerCardAnimStart\", _on_flow_player_card_anim_start)
		_event_bus.subscribe(\"Flow_PlayerCardAnimEnd\", _on_flow_player_card_anim_end)
		_event_bus.subscribe(\"Flow_EnemyCardReveal\", _on_flow_enemy_card_reveal)
		_event_bus.subscribe(\"Flow_CompareStart\", _on_flow_compare_start)
		_event_bus.subscribe(\"Flow_RoundEnd\", _on_flow_round_end)
		_event_bus.subscribe(\"Flow_BattleEnd\", _on_flow_battle_end)

func _setup_button_styles() -> void:
	_update_play_button_state()

# ========== 公开接口 ==========

## 初始化对战场景
func initialize_battle(enemy: EnemyData, player_cards: Array, enemy_cards: Array) -> void:
	_current_enemy = enemy
	_player_cards = player_cards
	_enemy_cards = enemy_cards

	# 根据敌方等级设置目标胜场
	match enemy.get_tier():
		EnemyData.EnemyTier.Grunt:
			_target_wins = 3
		EnemyData.EnemyTier.Elite:
			_target_wins = 4
		EnemyData.EnemyTier.Boss:
			_target_wins = 5
		_:
			_target_wins = 3

	# 更新UI
	_update_enemy_info()
	_create_player_cards()
	_create_enemy_cards()
	_reset_scores()
	_set_state(BattleState.PLAYER_SELECT)

	_add_dialog(\"对战开始！对抗 %s\" % enemy.get_enemy_name())
	emit_signal(\"battle_started\")

## 获取当前选中的卡牌索引
func get_selected_indices() -> Array[int]:
	return _selected_indices.duplicate()

## 获取当前选中的卡牌实例
func get_selected_cards() -> Array[CardInstance]:
	var cards: Array[CardInstance] = []
	for idx in _selected_indices:
		if idx >= 0 and idx < _player_cards.size():
			cards.append(_player_cards[idx])
	return cards

## 获取当前玩家手牌
func get_player_hand() -> Array[CardInstance]:
	return _player_cards.duplicate()

## 获取当前敌方手牌
func get_enemy_hand() -> Array[CardInstance]:
	return _enemy_cards.duplicate()

## 强制取消所有选择
func clear_selection() -> void:
	for idx in _selected_indices:
		if idx >= 0 and idx < _player_card_nodes.size():
			_player_card_nodes[idx].set_selected(false)
			_animate_card_deselect(_player_card_nodes[idx])
	_selected_indices.clear()
	_update_battle_area()
	_update_play_button_state()
	_add_dialog(\"已取消选择\")

## 重置场景
func reset() -> void:
	clear_selection()
	_reset_scores()
	_current_round = 0
	_set_state(BattleState.IDLE)
	_clear_battle_area()
	_update_round_display()

# ========== 状态管理 ==========

func _set_state(new_state: BattleState) -> void:
	var old_state = _current_state
	_current_state = new_state

	_debug(\"状态转换: %s -> %s\" % [_state_to_string(old_state), _state_to_string(new_state)])

	match new_state:
		BattleState.IDLE:
			_status_label.text = \"等待中...\"
			_enable_player_cards(false)
		BattleState.PLAYER_SELECT:
			_status_label.text = \"选择你的卡牌 (剩余 %d 张)\" % (MAX_SELECTIONS - _selected_indices.size())
			_enable_player_cards(true)
		BattleState.PLAYER_CONFIRM:
			_status_label.text = \"确认出牌\"
			_enable_player_cards(true)
		BattleState.BATTLE_COMPARE:
			_status_label.text = \"对战结算中...\"
			_enable_player_cards(false)
		BattleState.ROUND_RESULT:
			_status_label.text = \"回合结果\"
			_enable_player_cards(false)
		BattleState.BATTLE_END:
			_status_label.text = \"对战结束\"
			_enable_player_cards(false)

func _state_to_string(state: BattleState) -> String:
	match state:
		BattleState.IDLE: return \"IDLE\"
		BattleState.PLAYER_SELECT: return \"PLAYER_SELECT\"
		BattleState.PLAYER_CONFIRM: return \"PLAYER_CONFIRM\"
		BattleState.BATTLE_COMPARE: return \"BATTLE_COMPARE\"
		BattleState.ROUND_RESULT: return \"ROUND_RESULT\"
		BattleState.BATTLE_END: return \"BATTLE_END\"
	return \"UNKNOWN\"

# ========== 卡牌创建 ==========

func _create_player_cards() -> void:
	# 清除现有卡牌
	for node in _player_card_nodes:
		if is_instance_valid(node):
			node.queue_free()
	_player_card_nodes.clear()

	# 创建新卡牌
	for i in range(min(MAX_CARDS_IN_HAND, _player_cards.size())):
		var card = _player_cards[i]
		var card_ui = _create_card_ui(card, i, true)
		card_ui.card_clicked.connect(_on_card_clicked.bind(i))
		card_ui.card_hovered.connect(_on_card_hovered.bind(i))
		card_ui.card_unhovered.connect(_on_card_unhovered.bind(i))
		_player_card_container.add_child(card_ui)
		_player_card_nodes.append(card_ui)

func _create_enemy_cards() -> void:
	# 清除现有敌方卡牌
	for node in _enemy_card_nodes:
		if is_instance_valid(node):
			node.queue_free()
	_enemy_card_nodes.clear()

	# 创建敌方卡牌（背面显示）
	for i in range(min(MAX_CARDS_IN_HAND, _enemy_cards.size())):
		var card = _enemy_cards[i]
		var card_ui = _create_card_ui(card, i, false)
		card_ui.set_face_up(false)
		_enemy_card_container.add_child(card_ui)
		_enemy_card_nodes.append(card_ui)

func _create_card_ui(card: CardInstance, index: int, is_player: bool) -> CardUI:
	var card_ui = CardUI.new()

	# 设置基础属性
	card_ui.set_card_instance(card)
	card_ui.set_index(index)
	card_ui.set_is_player_card(is_player)

	# 获取卡牌原型信息
	if _data_manager:
		var proto = _data_manager.card_registry.get_prototype(card.get_prototype_id())
		if proto:
			card_ui.set_card_name(proto.prototype_id)
			var final_value = proto.base_value + card.get_delta_value()
			card_ui.set_card_value(final_value)

	return card_ui

# ========== 卡牌交互 ==========

func _on_card_clicked(index: int) -> void:
	if _current_state != BattleState.PLAYER_SELECT and _current_state != BattleState.PLAYER_CONFIRM:
		return

	if index in _selected_indices:
		# 取消选择
		_selected_indices.erase(index)
		_player_card_nodes[index].set_selected(false)
		_animate_card_deselect(_player_card_nodes[index])
		emit_signal(\"card_deselected\", index, _player_cards[index].get_card_id())
		_add_dialog(\"取消选择: %s\" % _player_card_nodes[index].get_card_name())
	else:
		# 选择卡牌
		if _selected_indices.size() >= MAX_SELECTIONS:
			_add_dialog(\"最多只能选择 %d 张卡牌！\" % MAX_SELECTIONS)
			return

		_selected_indices.append(index)
		_player_card_nodes[index].set_selected(true)
		_animate_card_select(_player_card_nodes[index])
		emit_signal(\"card_selected\", index, _player_cards[index].get_card_id())
		_add_dialog(\"选择: %s\" % _player_card_nodes[index].get_card_name())

	_update_battle_area()
	_update_play_button_state()

	# 状态转换
	if _selected_indices.size() == MAX_SELECTIONS:
		_set_state(BattleState.PLAYER_CONFIRM)
		_add_dialog(\"已选择 %d 张卡牌，点击\\\"打出\\\"确认出牌\" % MAX_SELECTIONS)
	else:
		_set_state(BattleState.PLAYER_SELECT)
		_status_label.text = \"选择你的卡牌 (剩余 %d 张)\" % (MAX_SELECTIONS - _selected_indices.size())

func _on_card_hovered(index: int) -> void:
	if _current_state != BattleState.PLAYER_SELECT:
		return

	if index not in _selected_indices:
		_animate_card_hover(_player_card_nodes[index])

func _on_card_unhovered(index: int) -> void:
	if index not in _selected_indices:
		_animate_card_unhover(_player_card_nodes[index])

# ========== 动画处理 ==========

func _animate_card_select(card_ui: CardUI) -> void:
	var tween = create_tween()
	tween.set_parallel(true)
	tween.tween_property(card_ui, \"scale\", Vector2(CARD_SCALE_SELECTED, CARD_SCALE_SELECTED), CARD_MOVE_DURATION)
	tween.tween_property(card_ui, \"position:y\", card_ui.position.y - 30, CARD_MOVE_DURATION)

func _animate_card_deselect(card_ui: CardUI) -> void:
	var tween = create_tween()
	tween.set_parallel(true)
	tween.tween_property(card_ui, \"scale\", Vector2(CARD_SCALE_NORMAL, CARD_SCALE_NORMAL), CARD_MOVE_DURATION)
	tween.tween_property(card_ui, \"position:y\", card_ui.position.y + 30, CARD_MOVE_DURATION)

func _animate_card_hover(card_ui: CardUI) -> void:
	var tween = create_tween()
	tween.tween_property(card_ui, \"scale\", Vector2(CARD_SCALE_HOVER, CARD_SCALE_HOVER), 0.15)
	tween.tween_property(card_ui, \"position:y\", card_ui.position.y - 15, 0.15)

func _animate_card_unhover(card_ui: CardUI) -> void:
	var tween = create_tween()
	tween.tween_property(card_ui, \"scale\", Vector2(CARD_SCALE_NORMAL, CARD_SCALE_NORMAL), 0.15)
	tween.tween_property(card_ui, \"position:y\", card_ui.position.y + 15, 0.15)

func _animate_card_reveal(card_ui: CardUI) -> void:
	card_ui.set_face_up(true)
	var tween = create_tween()
	tween.set_parallel(true)

	# 翻牌动画
	var original_modulate = card_ui.modulate
	tween.tween_property(card_ui, \"modulate:a\", 0.0, REVEAL_DURATION / 2)
	await tween.finished

	# 翻转后的显示
	tween = create_tween()
	tween.set_parallel(true)
	tween.tween_property(card_ui, \"modulate:a\", 1.0, REVEAL_DURATION / 2)
	tween.tween_property(card_ui, \"scale\", Vector2(1.2, 1.2), REVEAL_DURATION / 2)
	await tween.finished

	tween = create_tween()
	tween.tween_property(card_ui, \"scale\", Vector2(1.0, 1.0), 0.2)

func _animate_card_to_battle(card_ui: CardUI, target_container: HBoxContainer) -> void:
	# 从原位置移动到对战区域
	var world_pos = card_ui.global_position
	var target_pos = target_container.global_position + Vector2(target_container.size.x / 2, 0)

	card_ui.get_parent().remove_child(card_ui)
	target_container.add_child(card_ui)
	card_ui.position = Vector2.ZERO

	var tween = create_tween()
	tween.set_parallel(true)
	tween.tween_property(card_ui, \"position\", Vector2(0, 0), CARD_MOVE_DURATION)
	tween.tween_property(card_ui, \"scale\", Vector2(0.8, 0.8), CARD_MOVE_DURATION)

# ========== 按钮处理 ==========

func _on_play_button_pressed() -> void:
	if _selected_indices.size() != MAX_SELECTIONS:
		_add_dialog(\"请选择 %d 张卡牌！\" % MAX_SELECTIONS)
		return

	_add_dialog(\"确认出牌！\")
	emit_signal(\"selection_confirmed\", _selected_indices.duplicate())
	_set_state(BattleState.BATTLE_COMPARE)

func _on_cancel_button_pressed() -> void:
	clear_selection()
	_set_state(BattleState.PLAYER_SELECT)
	emit_signal(\"selection_cancelled\")

func _update_play_button_state() -> void:
	_play_button.disabled = _selected_indices.size() != MAX_SELECTIONS
	_cancel_button.disabled = _selected_indices.is_empty()

	# 更新按钮文字
	if _selected_indices.size() == MAX_SELECTIONS:
		_play_button.text = \"打 出\"
	elif _selected_indices.size() > 0:
		_play_button.text = \"选择中 (%d/%d)\" % [_selected_indices.size(), MAX_SELECTIONS]
	else:
		_play_button.text = \"打 出\"

# ========== 对战区域更新 ==========

func _update_battle_area() -> void:
	# 清空现有显示
	_clear_battle_area()

	# 显示玩家选中的卡牌
	var total_value = 0
	for idx in _selected_indices:
		if idx >= 0 and idx < _player_cards.size():
			var card = _player_cards[idx]
			var card_ui = _player_card_nodes[idx].duplicate()
			card_ui.scale = Vector2(0.8, 0.8)
			_player_selected_container.add_child(card_ui)

			# 计算总分
			if _data_manager:
				var proto = _data_manager.card_registry.get_prototype(card.get_prototype_id())
				if proto:
					total_value += proto.base_value + card.get_delta_value()

	_player_total_label.text = \"总分: %d\" % total_value

func _clear_battle_area() -> void:
	for child in _player_selected_container.get_children():
		_player_selected_container.remove_child(child)
		child.queue_free()

	for child in _enemy_selected_container.get_children():
		_enemy_selected_container.remove_child(child)
		child.queue_free()

	_enemy_total_label.text = \"总分: ?\"
	_battle_result_label.text = \" \"

# ========== 结果处理 ==========

func show_round_result(player_wins: bool, scores: Array[int]) -> void:
	_player_score = scores[0]
	_enemy_score = scores[1]

	_update_score_display()

	if player_wins:
		_battle_result_label.text = \"胜!\"
		_battle_result_label.add_theme_color_override(\"font_color\", Color.GREEN)
		_add_dialog(\"本回合: 胜利！\")
	else:
		_battle_result_label.text = \"败\"
		_battle_result_label.add_theme_color_override(\"font_color\", Color.RED)
		_add_dialog(\"本回合: 失败...\")

func reveal_enemy_cards(enemy_indices: Array[int]) -> void:
	_add_dialog(\"敌方出牌...\")

	# 显示敌方卡牌（带动画）
	for i in range(min(MAX_SELECTIONS, enemy_indices.size())):
		var idx = enemy_indices[i]
		if idx >= 0 and idx < _enemy_card_nodes.size():
			var card_ui = _enemy_card_nodes[idx].duplicate()
			_enemy_selected_container.add_child(card_ui)

			# 计算敌方总分
			if _data_manager and idx < _enemy_cards.size():
				var card = _enemy_cards[idx]
				var proto = _data_manager.card_registry.get_prototype(card.get_prototype_id())
				if proto:
					var value = proto.base_value + card.get_delta_value()
					_enemy_total_label.text = \"总分: %d\" % _calculate_enemy_total(enemy_indices)

			# 翻牌动画
			await get_tree().create_timer(REVEAL_DURATION * i).timeout
			_animate_card_reveal(card_ui)

func _calculate_enemy_total(indices: Array[int]) -> int:
	var total = 0
	for idx in indices:
		if idx >= 0 and idx < _enemy_cards.size():
			var card = _enemy_cards[idx]
			if _data_manager:
				var proto = _data_manager.card_registry.get_prototype(card.get_prototype_id())
				if proto:
					total += proto.base_value + card.get_delta_value()
	return total

# ========== UI更新 ==========

func _update_enemy_info() -> void:
	if _current_enemy:
		_enemy_name_label.text = _current_enemy.get_enemy_name()
	else:
		_enemy_name_label.text = \"神秘对手\"

func _update_score_display() -> void:
	_player_score_label.text = \"胜场: %d / %d\" % [_player_score, _target_wins]
	_enemy_score_label.text = \"胜场: %d / %d\" % [_enemy_score, _target_wins]

func _update_round_display() -> void:
	_round_label.text = \"第 %d 回合\" % _current_round

func _reset_scores() -> void:
	_player_score = 0
	_enemy_score = 0
	_current_round = 0
	_update_score_display()
	_update_round_display()

func _enable_player_cards(enabled: bool) -> void:
	for card_ui in _player_card_nodes:
		card_ui.set_interactable(enabled)

# ========== 对话系统 ==========

func _add_dialog(message: String) -> void:
	_dialog_text.append_text(\"\\n> \" + message)

	# 自动滚动到底部
	await get_tree().create_timer(0.01).timeout
	_dialog_text.scroll_following = true

	# 限制日志行数
	var lines = _dialog_text.text.split(\"\\n\")
	if lines.size() > 30:
		_dialog_text.text = \"\\n\".join(lines.slice(-30))

func _on_dialog_timer_timeout() -> void:
	pass  # 可以实现打字机效果

# ========== 事件处理 ==========

func _on_flow_battle_start(payload) -> void:
	_add_dialog(\"[Flow] 对战开始\")
	var enemy = payload.get(\"enemy\", null)
	if enemy:
		_add_dialog(\"遭遇敌人: %s\" % enemy.get_enemy_name())

func _on_flow_player_selecting(payload) -> void:
	_add_dialog(\"[Flow] 玩家选择阶段\")
	_set_state(BattleState.PLAYER_SELECT)

func _on_flow_player_card_anim_start(payload) -> void:
	_add_dialog(\"[Flow] 卡牌动画开始\")

func _on_flow_player_card_anim_end(payload) -> void:
	_add_dialog(\"[Flow] 卡牌动画结束\")

func _on_flow_enemy_card_reveal(payload) -> void:
	var card_id = payload.get(\"card_id\", \"\")
	_add_dialog(\"[Flow] 敌方卡牌揭示: %s\" % card_id)

func _on_flow_compare_start(payload) -> void:
	var player_cards = payload.get(\"player_cards\", [])
	var enemy_cards = payload.get(\"enemy_cards\", [])
	_add_dialog(\"[Flow] 开始比较: 玩家 %d vs 敌方 %d\" % [player_cards.size(), enemy_cards.size()])

func _on_flow_round_end(payload) -> void:
	var winner = payload.get(\"winner\", \"draw\")
	var scores = payload.get(\"scores\", [0, 0])
	_add_dialog(\"[Flow] 回合结束: %s 获胜! 比分 %d-%d\" % [winner, scores[0], scores[1]])

func _on_flow_battle_end(payload) -> void:
	var result = payload.get(\"result\", BattleEnums.EBattleResult.Defeat)
	if result == BattleEnums.EBattleResult.Victory:
		_add_dialog(\"==========\")
		_add_dialog(\"【胜利！】\")
		_add_dialog(\"==========\")
	else:
		_add_dialog(\"==========\")
		_add_dialog(\"【失败...】\")
		_add_dialog(\"==========\")
	_set_state(BattleState.BATTLE_END)

# ========== 工具函数 ==========

func _debug(message: String) -> void:
	# 开发调试用，正式版本可以注释掉
	# print(\"[BattleScene] \" + message)
	pass

# ========== 场景就绪回调 ==========

func _on_battle_scene_ready() -> void:
	_add_dialog(\"BattleScene 已就绪\")
	_debug(\"BattleScene ready\")


# ========== CardUI 子类定义 ==========
# 这个类应该在单独的文件中，但为了完整性在这里定义

class CardUI extends Control:
	signal card_clicked()
	signal card_hovered()
	signal card_unhovered()

	var _card_instance: CardInstance = null
	var _card_name: String = \"\"
	var _card_value: int = 0
	var _card_index: int = -1
	var _is_player_card: bool = true
	var _is_selected: bool = false
	var _is_face_up: bool = true
	var _is_interactable: bool = true

	# 样式
	var _style_normal: StyleBoxFlat
	var _style_hover: StyleBoxFlat
	var _style_selected: StyleBoxFlat

	func _init() -> void:
		custom_minimum_size = Vector2(100, 140)

		# 创建样式
		_style_normal = StyleBoxFlat.new()
		_style_normal.bg_color = Color(0.15, 0.15, 0.2, 0.9)
		_style_normal.border_width_left = 2
		_style_normal.border_width_top = 2
		_style_normal.border_width_right = 2
		_style_normal.border_width_bottom = 2
		_style_normal.border_color = Color(0.3, 0.3, 0.4, 1)
		_style_normal.corner_radius_top_left = 8
		_style_normal.corner_radius_top_right = 8
		_style_normal.corner_radius_bottom_right = 8
		_style_normal.corner_radius_bottom_left = 8

		_style_hover = StyleBoxFlat.new()
		_style_hover.bg_color = Color(0.2, 0.25, 0.35, 0.95)
		_style_hover.border_width_left = 3
		_style_hover.border_width_top = 3
		_style_hover.border_width_right = 3
		_style_hover.border_width_bottom = 3
		_style_hover.border_color = Color(0.6, 0.6, 0.8, 1)
		_style_hover.corner_radius_top_left = 10
		_style_hover.corner_radius_top_right = 10
		_style_hover.corner_radius_bottom_right = 10
		_style_hover.corner_radius_bottom_left = 10

		_style_selected = StyleBoxFlat.new()
		_style_selected.bg_color = Color(0.25, 0.3, 0.4, 0.95)
		_style_selected.border_width_left = 3
		_style_selected.border_width_top = 3
		_style_selected.border_width_right = 3
		_style_selected.border_width_bottom = 3
		_style_selected.border_color = Color(0.9, 0.8, 0.2, 1)
		_style_selected.corner_radius_top_left = 10
		_style_selected.corner_radius_top_right = 10
		_style_selected.corner_radius_bottom_right = 10
		_style_selected.corner_radius_bottom_left = 10

		add_theme_stylebox_override(\"panel\", _style_normal)

	func _ready() -> void:
		mouse_entered.connect(_on_mouse_entered)
		mouse_exited.connect(_on_mouse_exited)

	func _gui_input(event: InputEvent) -> void:
		if not _is_interactable:
			return
		if event is InputEventMouseButton:
			if event.pressed and event.button_index == MOUSE_BUTTON_LEFT:
				card_clicked.emit()

	func _on_mouse_entered() -> void:
		if not _is_interactable:
			return
		if not _is_selected:
			add_theme_stylebox_override(\"panel\", _style_hover)
			card_hovered.emit()

	func _on_mouse_exited() -> void:
		if not _is_selected:
			add_theme_stylebox_override(\"panel\", _style_normal)
			card_unhovered.emit()

	# Setter/Getter 方法
	func set_card_instance(instance: CardInstance) -> void:
		_card_instance = instance

	func get_card_instance() -> CardInstance:
		return _card_instance

	func set_card_name(name: String) -> void:
		_card_name = name

	func get_card_name() -> String:
		return _card_name

	func set_card_value(value: int) -> void:
		_card_value = value

	func get_card_value() -> int:
		return _card_value

	func set_index(index: int) -> void:
		_card_index = index

	func get_index() -> int:
		return _card_index

	func set_is_player_card(is_player: bool) -> void:
		_is_player_card = is_player

	func is_player_card() -> bool:
		return _is_player_card

	func set_selected(selected: bool) -> void:
		_is_selected = selected
		if selected:
			add_theme_stylebox_override(\"panel\", _style_selected)
		else:
			add_theme_stylebox_override(\"panel\", _style_normal)

	func is_selected() -> bool:
		return _is_selected

	func set_face_up(face_up: bool) -> void:
		_is_face_up = face_up
		queue_redraw()

	func is_face_up() -> bool:
		return _is_face_up

	func set_interactable(interactable: bool) -> void:
		_is_interactable = interactable
		mouse_filter = CONTROL.MOUSE_FILTER_IGNORE if not interactable else CONTROL.MOUSE_FILTER_STOP

	func _draw() -> void:
		# 绘制卡牌内容
		var rect = Rect2(Vector2.ZERO, size)

		if _is_player_card and _is_face_up:
			# 玩家卡牌正面
			draw_string(ThemeDB.fallback_font, Vector2(10, 25), _card_name, HORIZONTAL_ALIGNMENT_LEFT, size.x - 20, 16)
			draw_string(ThemeDB.fallback_font, Vector2(10, size.y - 15), \"价值: %d\" % _card_value, HORIZONTAL_ALIGNMENT_LEFT, size.x - 20, 14)
		else:
			# 背面或敌方卡牌
			draw_string(ThemeDB.fallback_font, Vector2(size.x / 2 - 20, size.y / 2), \"???\", HORIZONTAL_ALIGNMENT_LEFT, 40, 20)
"

